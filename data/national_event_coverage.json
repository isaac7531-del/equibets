{
  "version": 1,
  "coverage_goal": "Resolve national-event coverage to concrete FEI/NOC country codes and normalized eventing levels.",
  "source_notes": [
    "FEI states that National Federations are the authority for FEI disciplines in their countries and lists 135 full member National Federations plus one associate member in FEI Database.",
    "The all_fei_member_nations set includes full members and the current associate member so global national-event backfill can track every country-like FEI federation target.",
    "FEI Database uses NOC-style three-letter country codes rather than ISO alpha-3 codes for several federations, for example GER, SLO, TRI, and ISV."
  ],
  "source_urls": [
    "https://inside.fei.org/fei/about-fei/structure/national-federations",
    "https://inside.fei.org/fei/about-fei/governance/nfs/affiliation-process",
    "https://data.fei.org/NFPages/NF/Search"
  ],
